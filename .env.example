# Copia este archivo a .env.local (NO lo subas al repo)

# Provider principal: gemini | openai | auto
AI_PROVIDER=gemini
# Fallback opcional si el provider primario está sin cuota / rate-limit (openai|gemini|none)
AI_FALLBACK_PROVIDER=none

# --- Gemini (Google) ---
GEMINI_API_KEY=
# Ejemplos de modelos: gemini-2.0-flash, gemini-2.5-flash, gemini-3-flash-preview
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (fallback / opcional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Experience Hub ---
# URLs públicas de las plataformas que se abrirán desde /experiencia.
# El hub ya incluye las URLs productivas actuales; usa estas variables sólo si
# necesitas sustituirlas por otro ambiente (staging, demo, etc.).
NEXT_PUBLIC_ITSM_URL=
NEXT_PUBLIC_LEARNING_SUITE_URL=
NEXT_PUBLIC_SUITS_LEGAL_URL=
NEXT_PUBLIC_CRM_URL=
